[worldserver]

#
# Standalone Reagent Bank Account
#

#
#    ReagentBankAccount.Enable
#        Description: Enables the standalone .rbank command API used by the addon.
#        Default:     1
#
ReagentBankAccount.Enable = 1

#
#    ReagentBankAccount.AccountWide
#        Description: 0 = storage is per character.
#                     1 = storage is shared by all characters on the same account.
#        Default:     1
#
ReagentBankAccount.AccountWide = 1

#
#    ReagentBankAccount.AutoMigrate
#        Description: Automatically rewrites mod_reagent_bank_account rows when
#                     ReagentBankAccount.AccountWide changes.
#                     Character -> Account: sums all characters on the same account.
#                     Account -> Character: moves the shared account bank to the
#                     account's lowest GUID character because original ownership
#                     cannot be reconstructed after account-wide merge.
#        Default:     1
#
ReagentBankAccount.AutoMigrate = 1

#
#    ReagentBankAccount.MaxItemsPerPage
#        Description: Number of stored item rows returned to the addon per category page.
#                     Kept capped at 50 in C++ to avoid excessive chat protocol traffic.
#        Default:     16
#
ReagentBankAccount.MaxItemsPerPage = 16

#
#    ReagentBankAccount.EnableSharing
#        Description: Enables reagent bank sharing between players.
#                     AccountWide = 1: sharing is account-to-account (all characters on
#                                      each account see the shared bank).
#                     AccountWide = 0: sharing is character-to-character (only the invited
#                                      character sees the shared bank; other characters on
#                                      the same account are unaffected and may hold
#                                      independent share relationships).
#                     Members' items merge into the owner's bank on join.
#                     Items remain in the owner's bank if a member leaves or is kicked.
#
#                     WARNING: Do not change AccountWide after players have established
#                     share relationships. On mode change, all share memberships are
#                     cleared automatically, but items stay wherever they were at the
#                     time of the switch (i.e. merged into whichever bank accepted them).
#                     There is no way to reconstruct original ownership after a merge.
#                     Treat AccountWide as a set-and-forget option when sharing is in use.
#        Default:     0
#
ReagentBankAccount.EnableSharing = 0
